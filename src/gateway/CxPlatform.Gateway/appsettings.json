{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:5000" }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api",
        "Match": { "Path": "/api/{**catch-all}" }
      },
      "web-route": {
        "ClusterId": "web",
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "api": {
        "Destinations": {
          "api-d1": { "Address": "http://localhost:5001/" }
        }
      },
      "web": {
        "Destinations": {
          "web-d1": { "Address": "http://localhost:4200/" }
        }
      }
    }
  }
}
